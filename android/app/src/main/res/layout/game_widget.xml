<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_background_shape">


  <ImageView
    android:id="@+id/widget_background"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:scaleType="centerCrop"/>

  <TextView
    android:id="@+id/game_title"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="top|start"
    android:padding="8dp"
    android:textColor="#FFFFFF"
    android:textStyle="bold"
    android:textSize="14sp"/>

  <ViewFlipper
    android:id="@+id/view_flipper"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:inAnimation="@anim/widget_in"
    android:outAnimation="@anim/widget_out">


    <LinearLayout
      android:id="@+id/page_0"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="#AA000000"
      android:padding="8dp"
      android:orientation="horizontal"
      android:gravity="center_vertical">

      <ImageView android:id="@+id/store_logo_0"
        android:layout_width="20dp"
        android:layout_height="20dp"/>

      <TextView android:id="@+id/store_name_0"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginStart="6dp"/>

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView android:id="@+id/sale_price_0"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textStyle="bold"
          android:textSize="14sp"/>

        <TextView android:id="@+id/normal_price_0"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#AAAAAA"
          android:textSize="10sp"/>

        <TextView android:id="@+id/savings_0"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#00FF00"
          android:textSize="10sp"/>

      </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/page_1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:background="#AA000000"
      android:padding="8dp"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      >

      <ImageView android:id="@+id/store_logo_1"
        android:layout_width="20dp"
        android:layout_height="20dp"/>

      <TextView android:id="@+id/store_name_1"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginStart="6dp"/>

     <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView android:id="@+id/sale_price_1"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#FFFFFF"
          android:textStyle="bold"
          android:textSize="14sp"/>

        <TextView android:id="@+id/normal_price_1"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#AAAAAA"
          android:textSize="10sp"/>

        <TextView android:id="@+id/savings_1"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="#00FF00"
          android:textSize="10sp"/>

        </LinearLayout>
      </LinearLayout>
    </LinearLayout>
  </ViewFlipper>
</FrameLayout>
